# Copy this file to `.env` and fill in your own keys. NEVER commit a real .env.
# Perception is pinned to Gemini, so GEMINI_API_KEY is required. The router pool
# uses any of Cerebras/Groq/NVIDIA/GitHub. Tavily enables web_search (DuckDuckGo
# is the no-key fallback).

# --- required ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- router pool (any subset; more = better failover) ---
GROQ_API_KEY=your_groq_key_here
CEREBRAS_API_KEY=your_cerebras_key_here
NVIDIA_API_KEY=your_nvidia_key_here
GITHUB_ACCESS_TOKEN=your_github_token_here
OPEN_ROUTER_API_KEY=your_openrouter_key_here

# --- web search (optional; falls back to DuckDuckGo without it) ---
TAVILY_API_KEY=your_tavily_key_here

# --- optional model / routing overrides ---
NVIDIA_MODEL=deepseek-ai/deepseek-v3.2
GROQ_MODEL=openai/gpt-oss-120b
CEREBRAS_MODEL=zai-glm-4.7
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
GITHUB_MODEL=openai/gpt-4.1-mini
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=
LLM_ORDER=ollama,gemini,nvidia,groq,cerebras,openrouter,github
